{
  "name": "chat-grid-windows",
  "version": "0.1.0",
  "private": true,
  "description": "Windows desktop shell for Chat Grid.",
  "main": "src/main.cjs",
  "author": "Raywonder / TappedIn",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "start:local": "node scripts/start-local.cjs",
    "package:win": "electron-builder --win nsis portable",
    "dist:win": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "fm.tappedin.chatgrid",
    "productName": "Chat Grid",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
