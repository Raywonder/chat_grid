{
  "name": "endiginous-windows",
  "version": "0.4.4",
  "private": true,
  "description": "Windows desktop shell for Endiginous.",
  "main": "src/main.cjs",
  "author": "Raywonder / TappedIn",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "start:local": "node scripts/start-local.cjs",
    "build:web": "node scripts/build-web.cjs",
    "prepackage:win": "npm run build:web",
    "predist:win": "npm run build:web",
    "package:win": "electron-builder --win nsis portable",
    "dist:win": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "fm.tappedin.chatgrid",
    "productName": "Endiginous",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "web/**/*",
      "LICENSE",
      "THIRD_PARTY_NOTICES.md",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "license": "LICENSE"
    }
  }
}
