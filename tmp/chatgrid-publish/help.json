{
  "sections": [
    {
      "title": "Chat Grid Help",
      "items": [
        {
          "keys": "Arrow Keys",
          "description": "Move on the grid"
        },
        {
          "keys": "Shift+K / Applications / Shift+F10",
          "description": "Open the command palette in supported modes"
        },
        {
          "keys": "?",
          "description": "Open the main help viewer"
        },
        {
          "keys": "C",
          "description": "Speak your coordinates"
        },
        {
          "keys": "N",
          "description": "Change nickname"
        },
        {
          "keys": "Escape",
          "description": "Press once for the disconnect prompt, press again to disconnect"
        }
      ]
    },
    {
      "title": "Users and Chat",
      "items": [
        {
          "keys": "L",
          "description": "Locate nearest user"
        },
        {
          "keys": "Shift+L",
          "description": "List users; Enter teleports to that user, left/right arrow adjusts volume"
        },
        {
          "keys": "U",
          "description": "Speak connected users"
        },
        {
          "keys": "Slash",
          "description": "Start chat"
        },
        {
          "keys": "Slash commands",
          "description": "In chat, use /me <action>, /up for uptime, and /version for server version"
        },
        {
          "keys": "Shift+Z",
          "description": "Open admin menu when your role permissions allow it, including platform overview for administrators"
        },
        {
          "keys": "Comma / Period",
          "description": "Previous/next message"
        },
        {
          "keys": "Less Than / Greater Than",
          "description": "First/last message"
        }
      ]
    },
    {
      "title": "Items",
      "items": [
        {
          "keys": "I",
          "description": "Locate nearest item"
        },
        {
          "keys": "Shift+I",
          "description": "List items; Enter teleports to that item"
        },
        {
          "keys": "A",
          "description": "Add item"
        },
        {
          "keys": "O",
          "description": "Edit item properties"
        },
        {
          "keys": "Shift+O",
          "description": "Read all item properties"
        },
        {
          "keys": "D",
          "description": "Pick up/drop item"
        },
        {
          "keys": "Z",
          "description": "Item management (delete/transfer when permitted)"
        },
        {
          "keys": "Space in item menus",
          "description": "Read tooltip or help for the selected item action or property"
        },
        {
          "keys": "Enter",
          "description": "Use item"
        },
        {
          "keys": "Shift+Enter",
          "description": "Use the selected item's secondary action when it has one"
        }
      ]
    },
    {
      "title": "Audio",
      "items": [
        {
          "keys": "P",
          "description": "Ping server"
        },
        {
          "keys": "M",
          "description": "Mute/unmute yourself"
        },
        {
          "keys": "Shift+M",
          "description": "Toggle stereo/mono output"
        },
        {
          "keys": "! (Shift+1)",
          "description": "Toggle loopback monitor"
        },
        {
          "keys": "1",
          "description": "Toggle voice layer"
        },
        {
          "keys": "2",
          "description": "Toggle item sounds layer"
        },
        {
          "keys": "3",
          "description": "Toggle media layer"
        },
        {
          "keys": "4",
          "description": "Toggle world layer"
        },
        {
          "keys": "E",
          "description": "Select voice effect"
        },
        {
          "keys": "Underscore or Plus",
          "description": "Lower/raise active effect value"
        },
        {
          "keys": "Dash or Equals",
          "description": "Lower/raise master volume"
        },
        {
          "keys": "V",
          "description": "Set mic volume"
        },
        {
          "keys": "Shift+V",
          "description": "Microphone calibration"
        }
      ]
    },
    {
      "title": "Text, Menus, and Commands",
      "items": [
        {
          "keys": "Enter / Escape",
          "description": "Confirm or cancel in text entry, menus, and dialogs"
        },
        {
          "keys": "Arrow Up / Arrow Down",
          "description": "Move through menu and list choices"
        },
        {
          "keys": "Page Up / Page Down",
          "description": "Jump larger steps in numeric and long property option lists"
        },
        {
          "keys": "Home / End",
          "description": "Move to the start or end in text fields and help viewer"
        },
        {
          "keys": "Ctrl+A/C/X/V or Cmd+A/C/X/V",
          "description": "Select all, copy, cut, and paste in text entry fields"
        },
        {
          "keys": "First letter",
          "description": "Jump to the next matching entry in most command and list menus"
        }
      ]
    },
    {
      "title": "Admin",
      "items": [
        {
          "keys": "Shift+Z",
          "description": "Open the admin menu when your role has admin actions, including platform overview for administrators"
        },
        {
          "keys": "Space",
          "description": "Read help for the selected admin action"
        },
        {
          "keys": "Enter",
          "description": "Run a selected admin action such as platform overview, role management, user role changes, bans, unbans, or account deletion when permitted"
        }
      ]
    },
    {
      "title": "Piano Mode",
      "items": [
        {
          "keys": "1-9 / 0",
          "description": "Switch instrument preset slots"
        },
        {
          "keys": "A S D F G H J K L ; '",
          "description": "Play white keys"
        },
        {
          "keys": "W E T Y U O P ]",
          "description": "Play sharps"
        },
        {
          "keys": "Minus / Equals",
          "description": "Shift octave down or up"
        },
        {
          "keys": "Z / X / Enter / C",
          "description": "Record, play recording, play demo, or stop piano playback"
        },
        {
          "keys": "? / Escape",
          "description": "Open piano help or exit piano mode"
        }
      ]
    },
    {
      "title": "Help Viewer",
      "items": [
        {
          "keys": "Arrow Up / Arrow Down",
          "description": "Read the previous or next help line"
        },
        {
          "keys": "Home / End",
          "description": "Jump to the first or last help line"
        },
        {
          "keys": "Escape",
          "description": "Close help and return to the previous mode"
        }
      ]
    }
  ]
}
